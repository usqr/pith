{
  "name": "pith",
  "version": "0.1.0",
  "description": "State-of-the-art token optimization for Claude Code. Compresses tool results automatically, optimizes prompt caching, auto-compacts context, enforces structured output formats, and builds a persistent project wiki.",
  "author": {
    "name": "Pith",
    "url": "https://github.com/abhisekjha/pith"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js",
            "timeout": 10,
            "statusMessage": "Pith: initializing..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/prompt-submit.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.js",
            "timeout": 10,
            "statusMessage": "Pith: compressing..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/stop.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
